{
  "entities": {
    "EpisodicMemory": {
      "title": "Episodic Memory",
      "description": "A single interaction log in the Short-Term Memory tier.",
      "type": "object",
      "properties": {
        "interactionId": { "type": "string", "description": "Unique ID for the interaction" },
        "sessionId": { "type": "string", "description": "ID of the current session" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the interaction occurred" },
        "actor": { "type": "string", "enum": ["user", "agent", "system"], "description": "Who performed the action" },
        "rawText": { "type": "string", "description": "The verbatim text of the interaction" }
      },
      "required": ["interactionId", "sessionId", "timestamp", "actor", "rawText"]
    },
    "GraphNode": {
      "title": "Graph Node",
      "description": "A node in the Medium-Term Memory graph.",
      "type": "object",
      "properties": {
        "nodeId": { "type": "string" },
        "type": { "type": "string", "enum": ["episodic", "semantic"] },
        "content": { "type": "string" },
        "embedding": { "type": "array", "items": { "type": "number" } },
        "metadata": { "type": "object" },
        "pageRank": { "type": "number" },
        "communityId": { "type": "string" }
      },
      "required": ["nodeId", "type", "content"]
    },
    "SemanticFact": {
      "title": "Semantic Fact",
      "description": "A distilled fact in the Long-Term Memory tier.",
      "type": "object",
      "properties": {
        "knowledgeId": { "type": "string" },
        "distilledFact": { "type": "string" },
        "embedding": { "type": "array", "items": { "type": "number" } },
        "lastAccessed": { "type": "string", "format": "date-time" },
        "provenance": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["knowledgeId", "distilledFact", "embedding"]
    }
  },
  "firestore": {
    "/stm/{interactionId}": {
      "schema": "EpisodicMemory",
      "description": "Short-Term Memory episodic logs."
    },
    "/mtm/{nodeId}": {
      "schema": "GraphNode",
      "description": "Medium-Term Memory associative graph nodes."
    },
    "/ltm/{knowledgeId}": {
      "schema": "SemanticFact",
      "description": "Long-Term Memory distilled semantic facts."
    }
  }
}
