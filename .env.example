# PostgreSQL (pgvector)
DATABASE_URL=postgresql://nhrag:nhrag_dev@localhost:5432/nhrag

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nhrag_dev_password

# Embedding / LLM provider: "gemini" or "openai"
EMBEDDING_PROVIDER=gemini

# Google Gemini (required if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Docling sidecar
DOCLING_SERVICE_URL=http://localhost:8081/parse
